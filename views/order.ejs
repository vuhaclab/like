<%- include("./partials/layout-start", { pageTitle, notice, error }) %>

<div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
  <section class="rounded-3xl border-4 border-black bg-dracula-surface p-6 shadow-brutal">
    <p class="text-sm uppercase tracking-[0.35em] text-dracula-muted">Services</p>
    <h2 class="mt-2 text-3xl font-black">Chọn dịch vụ</h2>
    <p class="mt-3 text-dracula-muted">Tạo order nhanh theo từng loại dịch vụ phổ biến.</p>

    <div class="mt-6 space-y-3">
      <% services.forEach((item) => { %>
        <a
          href="/orders/<%= item.id %>"
          class="flex items-center justify-between rounded-2xl border-4 border-black px-4 py-4 shadow-brutal <%= service.id === item.id ? 'bg-dracula-primary text-black' : 'bg-dracula-panel text-dracula-text' %>"
        >
          <div>
            <p class="font-black text-lg"><%= item.name %></p>
            <p class="text-sm <%= service.id === item.id ? 'text-black/70' : 'text-dracula-muted' %>">
              Min <%= item.min.toLocaleString("vi-VN") %> · Max <%= item.max.toLocaleString("vi-VN") %> · <%= item.price.toLocaleString("vi-VN") %>/1k
            </p>
          </div>
          <i class="fa-solid fa-arrow-right text-xl"></i>
        </a>
      <% }) %>
    </div>
  </section>

  <section class="space-y-6">
    <div class="rounded-3xl border-4 border-black bg-dracula-panel p-6 shadow-brutal">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm uppercase tracking-[0.35em] text-dracula-muted">Create order</p>
          <h2 class="mt-2 text-3xl font-black"><%= service.name %></h2>
        </div>
        <div class="rounded-2xl border-4 border-black bg-dracula-pink px-4 py-3 font-black text-black shadow-brutal">
          <i class="fa-solid fa-tags mr-2"></i><%= service.price.toLocaleString("vi-VN") %>/1k
        </div>
      </div>

      <form action="/orders/<%= service.id %>" method="post" class="mt-6 space-y-4">
        <div>
          <label class="mb-2 block text-sm font-bold">Link hoặc mục tiêu</label>
          <div class="flex items-center gap-3 rounded-2xl border-4 border-black bg-dracula-surface px-4 py-3 shadow-brutal">
            <i class="fa-solid fa-link text-dracula-cyan"></i>
            <input
              name="target"
              type="text"
              placeholder="https://..."
              class="w-full bg-transparent outline-none placeholder:text-dracula-muted"
            />
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-bold">Số lượng</label>
            <div class="flex items-center gap-3 rounded-2xl border-4 border-black bg-dracula-surface px-4 py-3 shadow-brutal">
              <i class="fa-solid fa-hashtag text-dracula-yellow"></i>
              <input
                name="quantity"
                id="order-quantity"
                type="number"
                min="<%= service.min %>"
                max="<%= service.max %>"
                placeholder="<%= service.min %>"
                class="w-full bg-transparent outline-none placeholder:text-dracula-muted"
              />
            </div>
          </div>

          <div>
            <label class="mb-2 block text-sm font-bold">Loại dịch vụ</label>
            <div class="rounded-2xl border-4 border-black bg-dracula-surface px-4 py-3 font-bold shadow-brutal">
              <%= service.name %>
            </div>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-3">
          <button type="button" onclick="addQuantity(100)" class="rounded-2xl border-4 border-black bg-dracula-panel px-4 py-3 font-black shadow-brutal">+100</button>
          <button type="button" onclick="addQuantity(500)" class="rounded-2xl border-4 border-black bg-dracula-panel px-4 py-3 font-black shadow-brutal">+500</button>
          <button type="button" onclick="addQuantity(1000)" class="rounded-2xl border-4 border-black bg-dracula-panel px-4 py-3 font-black shadow-brutal">+1000</button>
        </div>

        <div class="rounded-2xl border-4 border-black bg-dracula-surface p-4 text-center">
            <p class="text-sm text-dracula-muted uppercase font-bold">Tổng chi phí dự kiến</p>
            <p class="text-2xl font-black text-dracula-green" id="total-cost">0đ</p>
        </div>

        <button
          type="submit"
          class="w-full rounded-2xl border-4 border-black bg-dracula-primary px-5 py-4 text-lg font-black text-black shadow-brutal"
        >
          <i class="fa-solid fa-bullhorn mr-2"></i>Tạo order
        </button>
      </form>
    </div>

    <div class="rounded-3xl border-4 border-black bg-dracula-surface p-6 shadow-brutal">
      <p class="text-sm uppercase tracking-[0.35em] text-dracula-muted">Rules</p>
      <h3 class="mt-2 text-2xl font-black">Điều kiện tạo order</h3>
      <div class="mt-5 grid gap-3">
        <div class="rounded-2xl border-4 border-black bg-dracula-panel p-4">
          <p class="font-black text-dracula-green">1. Mục tiêu hợp lệ</p>
          <p class="mt-1 text-sm text-dracula-muted">Nhập link bài viết, profile hoặc video tuỳ dịch vụ.</p>
        </div>
        <div class="rounded-2xl border-4 border-black bg-dracula-panel p-4">
          <p class="font-black text-dracula-cyan">2. Đúng số lượng</p>
          <p class="mt-1 text-sm text-dracula-muted">Mỗi dịch vụ có min/max riêng.</p>
        </div>
        <div class="rounded-2xl border-4 border-black bg-dracula-panel p-4">
          <p class="font-black text-dracula-yellow">3. Xử lý tự động</p>
          <p class="mt-1 text-sm text-dracula-muted">Đơn sẽ được ghi nhận ngay sau khi tạo.</p>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  const pricePer1k = <%= service.price %>;
  const qtyInput = document.getElementById('order-quantity');
  const totalDisplay = document.getElementById('total-cost');

  function updateCost() {
    const qty = parseInt(qtyInput.value) || 0;
    const total = Math.ceil((qty / 1000) * pricePer1k);
    totalDisplay.innerText = total.toLocaleString('vi-VN') + 'đ';
  }

  function addQuantity(amount) {
    qtyInput.value = (parseInt(qtyInput.value) || 0) + amount;
    updateCost();
  }

  qtyInput.addEventListener('input', updateCost);
</script>
<%- include("./partials/layout-end") %>
