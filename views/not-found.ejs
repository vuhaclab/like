<%- include("./partials/layout-start", { pageTitle, notice, error }) %>

<div class="mx-auto max-w-3xl text-center">
  <div class="rounded-3xl border-4 border-black bg-dracula-surface p-8 shadow-brutal">
    <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full border-4 border-black bg-dracula-red text-black shadow-brutal">
      <i class="fa-solid fa-circle-exclamation text-5xl"></i>
    </div>
    <p class="mt-6 text-sm uppercase tracking-[0.35em] text-dracula-muted">404 Error</p>
    <h2 class="mt-2 text-4xl font-black">Không tìm thấy trang</h2>
    <p class="mt-4 text-dracula-muted">
      Trang bạn đang truy cập không tồn tại hoặc đã được chuyển sang đường dẫn khác.
    </p>

    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href="/dashboard"
        class="rounded-2xl border-4 border-black bg-dracula-primary px-5 py-3 font-black text-black shadow-brutal"
      >
        <i class="fa-solid fa-gauge-high mr-2"></i>Về Dashboard
      </a>
      <a
        href="/login"
        class="rounded-2xl border-4 border-black bg-dracula-panel px-5 py-3 font-black shadow-brutal"
      >
        <i class="fa-solid fa-right-to-bracket mr-2"></i>Đăng nhập
      </a>
    </div>
  </div>
</div>

<%- include("./partials/layout-end") %>
